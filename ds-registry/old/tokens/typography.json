{
  "$schema": "dropi-ds-token",
  "category": "typography",
  "source": "Figma — -WEB- components",
  "fontFamily": {
    "primary": "'Inter', sans-serif",
    "secondary": "'IBM Plex Sans', sans-serif",
    "mono": "'JetBrains Mono', monospace"
  },
  "fontSize": {
    "xs": "12px",
    "sm": "14px",
    "md": "15px",
    "base": "16px",
    "lg": "18px",
    "xl": "20px",
    "2xl": "24px",
    "3xl": "30px",
    "4xl": "36px"
  },
  "fontWeight": {
    "regular": 400,
    "medium": 500,
    "semibold": 600,
    "bold": 700,
    "extrabold": 800
  },
  "lineHeight": {
    "tight": 1.25,
    "normal": 1.5,
    "relaxed": 1.75
  },
  "namedStyles": {
    "Body-M-Regular": {
      "family": "Inter",
      "weight": 400,
      "size": "14px",
      "lineHeight": 1.5
    },
    "Body-M-Medium": {
      "family": "Inter",
      "weight": 500,
      "size": "14px",
      "lineHeight": 1.5
    },
    "Menu-Item": {
      "family": "IBM Plex Sans",
      "weight": 500,
      "size": "15px",
      "lineHeight": 1
    }
  }
}
